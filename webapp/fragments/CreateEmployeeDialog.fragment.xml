<core:FragmentDefinition xmlns="sap.m" xmlns:f="sap.ui.layout.form" 
                         xmlns:core="sap.ui.core">
    
    <Dialog id="employeeDialog" title="{view>/dialogTitle}">
        <f:SimpleForm id="employeeForm" editable="true" layout="ResponsiveGridLayout"
                      labelSpanL="4" emptySpanL="1" columnsL="1">
            <f:content>
                <Label text="First Name *"/>
                <Input value="{view>/tempData/fName}" required="true"/>
                
                <Label text="Last Name *"/>
                <Input value="{view>/tempData/lName}" required="true"/>
                
                <Label text="Email"/>
                <Input value="{view>/tempData/email}" type="Email"/>
                
                <Label text="Phone"/>
                <Input value="{view>/tempData/phone}" type="Tel"/>
                
                <Label text="City *"/>
                <Input value="{view>/tempData/address/0/city}" required="true"/>
                
                <Label text="Street"/>
                <Input value="{view>/tempData/address/0/address}"/>
                
                <Label text="Gender"/>
                <Select selectedKey="{view>/tempData/gender}">
                    <core:Item key="Male" text="Male"/>
                    <core:Item key="Female" text="Female"/>
                </Select>
            </f:content>
        </f:SimpleForm>
        
        <beginButton>
            <Button text="Save" press="onSaveDialog" type="Emphasized"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCancelDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
