<Page >

        <content>
	<Table id="idProductsTable"
		inset="false"
		mode="MultiSelect"
		items="{
			path: '/employee',
			sorter: {
				path: 'Name'
			}
		}">
			<headerToolbar>
			<OverflowToolbar>
				<content>
					<Title text="Employees" level="H2"/>
					<ToolbarSpacer />

					<Button text="Create" press="onCreate"></Button>
					<Button text="Edit" press="onEdit"></Button>
					<Button text="Delete" press="onDelete"></Button>
					
				</content>
			</OverflowToolbar>
		</headerToolbar>
		<infoToolbar>
			<OverflowToolbar>
				<Label text="Employee Details"/>
			</OverflowToolbar>
		</infoToolbar>
		<columns>
		<Column
				width="12em">
				<Text text="ID" />
				
			</Column>
			<Column
				width="12em">
				<Text text="First Name" />
				
			</Column>
			<Column
				minScreenWidth="Tablet"
				demandPopin="true">
				<Text text="Second Name" />
			</Column>
			<Column
				minScreenWidth="Desktop"
				demandPopin="true"
				>
				<Text text="Age" />
			</Column>
			<Column
				minScreenWidth="Desktop"
				demandPopin="true"
				>
				<Text text="gender" />
			</Column>
			
		</columns>
		<items>
			<ColumnListItem vAlign="Middle"   type="Navigation" press="onEmployeePress" >
				<cells>
				<Text
						text="{ID}" />
					
					<Text
						text="{fName}" />
					<Text
						text="{lName}" />
                        <Text
						text="{age}" />
                        
					<Text
						text="{gender}" />
				</cells>
			</ColumnListItem>
		</items>
	</Table>
	 </content>

    </Page>

</mvc:View>
