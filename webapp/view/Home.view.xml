	<Table id="idProductsTable"
		inset="false"
		items="{
			path: '/employee',
			sorter: {
				path: 'Name'
			}
		}">
		
		<infoToolbar>
			<OverflowToolbar>
				<Label text="Wide range of available products"/>
			</OverflowToolbar>
		</infoToolbar>
		<columns>
			<Column
				width="12em">
				<Text text="First Name" />
				<dependents>
					<p:ColumnAIAction press="onAIActionPress"></p:ColumnAIAction>
				</dependents>
			</Column>
			<Column
				minScreenWidth="Tablet"
				demandPopin="true">
				<Text text="Second Name" />
			</Column>
			<Column
				minScreenWidth="Desktop"
				demandPopin="true"
				>
				<Text text="Age" />
			</Column>
			<Column
				minScreenWidth="Desktop"
				demandPopin="true"
				>
				<Text text="gender" />
			</Column>
			
		</columns>
		<items>
			<ColumnListItem vAlign="Middle">
				<cells>
					
					<Text
						text="{fName}" />
					<Text
						text="{lName}" />
                        <Text
						text="{age}" />
                        
					<Text
						text="{gender}" />
				</cells>
			</ColumnListItem>
		</items>
	</Table>

</mvc:View>
