<mvc:View xmlns:mvc="sap.ui.core.mvc"
		    xmlns="sap.uxap"
		   xmlns:layout="sap.ui.layout"
		   xmlns:m="sap.m"
		  
		  
		   controllerName="com.app.testproject.controller.EmployeeObject"
		   height="100%">
	<ObjectPageLayout id="ObjectPageLayout"
		enableLazyLoading="true"
		beforeNavigate="onBeforeNavigate"
		useIconTabBar="true"
		showTitleInHeaderContent="true"
		upperCaseAnchorBar="false">
		<headerTitle>
			<ObjectPageDynamicHeaderTitle>
				<expandedHeading>
					<m:Title text="{fName} {lName}" wrapping="true"/>
				</expandedHeading>

			

				<expandedContent>
					<m:Text text="Senior UI Developer"/>
				</expandedContent>

				<snappedContent>
					<m:Text text="Senior UI Developer"/>
				</snappedContent>

				<snappedTitleOnMobile>
					<m:Title text="Senior UI Developer"/>
				</snappedTitleOnMobile>

				<actions>
					<m:Button text="Edit" type="Emphasized" press="onEdit"/>
					<m:Button type="Transparent" text="Delete"/>
					<m:Button type="Transparent" text="Copy"/>
					<m:OverflowToolbarButton icon="sap-icon://action" type="Transparent" text="Share" tooltip="action"/>
				</actions>
			</ObjectPageDynamicHeaderTitle>
		</headerTitle>

		<headerContent>
			<m:FlexBox wrap="Wrap" fitContainer="true" >
				

				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
					<m:Link text="{phone}"/>
					<m:Link text="{email}"/>
				</layout:VerticalLayout>

		

				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
					<m:Label text="Hello! I am {fName} {lName} and I use UxAP"/>
					<m:VBox>
						<m:Label text="Achieved goals"/>
						<m:ProgressIndicator percentValue="30" displayValue="30%"/>
					</m:VBox>
				</layout:VerticalLayout>

				<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
					<m:Label text="{address/0/city}"/>
				</layout:VerticalLayout>
			</m:FlexBox>
		</headerContent>

		<sections>
			<ObjectPageSection titleUppercase="false" id="goals" title="Address">
			<subSections>
				<ObjectPageSubSection id="address" titleUppercase="false">
					<blocks>

                    <m:VBox>
                        <m:Label text="City"/>
                        <m:Text text="{address/0/city}"/>

                        <m:Label text="Street"/>
                        <m:Text text="{address/0/street}"/>
						<m:Label text="Landmark"/>
                        <m:Text text="{address/0/landmark}"/>
                    </m:VBox>

                </blocks>
				</ObjectPageSubSection>
			</subSections>
			</ObjectPageSection>
			<ObjectPageSection titleUppercase="false" id="Salary" title="Salary">
			<subSections>
				<ObjectPageSubSection id="Salary_id" titleUppercase="false">
					<blocks>

                    <m:VBox>
                        <m:Label text="Cost To Company"/>
                        <m:Text text="{salary/costToCompany}"/>

                        <m:Label text="Employee Pf"/>
                        <m:Text text="{salary/employeePf}"/>
						 <m:Label text="Employer Pf"/>
                        <m:Text text="{salary/employerPf}"/>
                    </m:VBox>

                </blocks>
				</ObjectPageSubSection>
			</subSections>
			</ObjectPageSection>

			
		</sections>
	</ObjectPageLayout>
</mvc:View>
